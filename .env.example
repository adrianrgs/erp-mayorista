# ─── FRONTEND (Vite) — variables VITE_* expuestas al bundle del navegador ────────
# URL base de la API NestJS. En producción DEBE apuntar al backend real (no localhost).
VITE_API_URL="http://localhost:3001/api"

# Config web de Firebase (solo se usa Storage para comprobantes). No son secretos, pero
# permiten apuntar a otro proyecto por entorno. Si se omiten, se usan los valores por defecto.
VITE_FIREBASE_PROJECT_ID="foratour-erp-2026"
VITE_FIREBASE_APP_ID="1:982546946974:web:f7436bc4dbd7eeecb3d48f"
VITE_FIREBASE_STORAGE_BUCKET="foratour-erp-2026.firebasestorage.app"
VITE_FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="foratour-erp-2026.firebaseapp.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="982546946974"

# ─── BACKEND (NestJS, apps/api) — NO exponer al navegador ────────────────────────
# Secreto para firmar/verificar los JWT. OBLIGATORIO en producción (valor largo y aleatorio).
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="8h"

# Origen permitido por CORS. En producción, el dominio del frontend (no localhost).
CORS_ORIGIN="http://localhost:3000"

# Puerto del backend.
PORT="3001"

# Firebase Admin / Data Connect (Cloud SQL) — acceso a la base desde el backend.
# El endpoint de Data Connect NO debe ser accesible públicamente (los connectors están con
# @auth(level: PUBLIC); el acceso real es frontend → NestJS → Data Connect).
FIREBASE_PROJECT_ID="foratour-erp-2026"
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccount.json"

PORT=3001

# Firebase Admin (SOLO para desarrollo local).
# Descarga la llave desde Firebase Console > Configuración del proyecto > Cuentas de servicio.
# En producción (Cloud Run / App Hosting) NO se usa: el backend toma las credenciales
# automáticas del entorno (ADC), así que esta variable se deja vacía allí.
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_PROJECT_ID=foratour-erp-2026

# Data Connect
DATA_CONNECT_LOCATION=us-central1
DATA_CONNECT_SERVICE_ID=foratour-erp
DATA_CONNECT_CONNECTOR_ID=foratour-erp-connector

# JWT Auth
# ⚠️ NO pongas el secreto real aquí (este archivo está en git). Genera uno con:
#   openssl rand -base64 48
# En local ponlo en tu .env (ignorado por git). En producción va en Secret Manager.
JWT_SECRET=CAMBIAME_genera_con_openssl_rand_base64_48
JWT_EXPIRES_IN=8h

# Contraseña del usuario "admin" sembrado la PRIMERA vez que la tabla Usuario está vacía
# (ver SeedService). No tiene efecto si ya existen usuarios. En producción va en Secret Manager.
SEED_ADMIN_PASSWORD=CAMBIAME_antes_del_primer_arranque

# CORS - origen(es) del frontend, separados por coma. Ej. en producción:
#   https://www.margariteno.com,https://margariteno.com
CORS_ORIGIN=http://localhost:3000

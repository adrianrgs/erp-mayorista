PORT=3001

# Firebase Admin - descarga desde Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_PROJECT_ID=foratour-erp-2026

# Data Connect
DATA_CONNECT_LOCATION=us-central1
DATA_CONNECT_SERVICE_ID=foratour-erp
DATA_CONNECT_CONNECTOR_ID=foratour-erp-connector

# JWT Auth
JWT_SECRET= Expelliarmus0125
JWT_EXPIRES_IN=8h

# Contraseña del usuario "admin" sembrado automáticamente la primera vez que la
# tabla Usuario esté vacía (ver SeedService). Cambiarla acá antes del primer
# arranque en un ambiente nuevo; no tiene efecto si ya existen usuarios.
SEED_ADMIN_PASSWORD=foratour2026

# CORS - origen del frontend React
CORS_ORIGIN=http://localhost:3000
